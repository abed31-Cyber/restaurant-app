generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🏢 TENANT - Restaurant
model Restaurant {
  id                String             @id @default(uuid())
  name              String
  slug              String             @unique
  address           String
  phone             String
  email             String
  logoUrl           String?
  primaryColor      String?            @default("#F97316")
  description       String?
  subscriptionStatus SubscriptionStatus @default(TRIAL)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  // Relations
  users        User[]
  categories   Category[]
  dishes       Dish[]
  orders       Order[]
  reservations Reservation[]
  reviews      Review[]
  openingHours OpeningHours[]
  subscription Subscription?

  @@index([slug])
  @@index([subscriptionStatus])
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
}

// 👤 UTILISATEURS (RBAC)
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  name          String?
  role          UserRole @default(CLIENT)
  restaurantId  String?
  emailVerified DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  restaurant   Restaurant?  @relation(fields: [restaurantId], references: [id])
  orders       Order[]
  reservations Reservation[]
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  KITCHEN
  CLIENT
}

// 🕐 HORAIRES D'OUVERTURE
model OpeningHours {
  id           String     @id @default(uuid())
  restaurantId String
  dayOfWeek    Int // 0-6 (Dimanche-Samedi)
  openTime     String // "11:30"
  closeTime    String // "22:00"
  isClosed     Boolean    @default(false)
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, dayOfWeek])
}

// 🍽 CATÉGORIES DE MENU
model Category {
  id           String     @id @default(uuid())
  name         String
  description  String?
  sortOrder    Int        @default(0)
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  dishes       Dish[]

  @@index([restaurantId])
}

// 🍕 PLATS
model Dish {
  id           String       @id @default(uuid())
  name         String
  description  String?
  price        Decimal      @db.Decimal(10, 2)
  imageUrl     String?
  isAvailable  Boolean      @default(true)
  isSpicy      Boolean      @default(false)
  isVegetarian Boolean      @default(false)
  allergens    String[]     @default([])
  categoryId   String
  restaurantId String
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  category   Category     @relation(fields: [categoryId], references: [id])
  restaurant Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  options    DishOption[]
  orderItems OrderItem[]

  @@index([restaurantId, categoryId])
  @@index([isAvailable])
}

// 🧂 OPTIONS/MODIFIERS DE PLATS
model DishOption {
  id          String  @id @default(uuid())
  dishId      String
  name        String // "Supplément fromage"
  price       Decimal @db.Decimal(10, 2)
  isAvailable Boolean @default(true)
  dish        Dish    @relation(fields: [dishId], references: [id], onDelete: Cascade)
}

// 🛒 COMMANDES
model Order {
  id            String      @id @default(uuid())
  restaurantId  String
  userId        String?
  status        OrderStatus @default(PENDING)
  type          OrderType   @default(PICKUP)
  totalPrice    Decimal     @db.Decimal(10, 2)
  subtotal      Decimal     @db.Decimal(10, 2)
  paymentMethod PaymentMethod @default(ONLINE)
  paymentStatus PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  pickupTime    DateTime?
  notes         String?
  customerName  String?
  customerPhone String?
  customerEmail String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  restaurant Restaurant  @relation(fields: [restaurantId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  items      OrderItem[]

  @@index([restaurantId, status])
  @@index([createdAt])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  PICKUP
  DELIVERY
  DINE_IN
}

enum PaymentMethod {
  ONLINE
  CASH
  CARD_ON_SITE
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  dishId    String
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)
  options   Json? // [{"name": "Supplément fromage", "price": 1.00}]
  notes     String? // "Sans oignons"

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish  Dish  @relation(fields: [dishId], references: [id])
}

// 📅 RÉSERVATIONS
model Reservation {
  id           String            @id @default(uuid())
  restaurantId String
  userId       String?
  name         String
  email        String
  phone        String
  date         DateTime
  time         String // "19:30"
  guests       Int
  status       ReservationStatus @default(PENDING)
  notes        String?
  tableNumber  String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])

  @@index([restaurantId, date])
  @@index([status])
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

// ⭐ AVIS CLIENTS
model Review {
  id           String   @id @default(uuid())
  restaurantId String
  orderId      String?
  name         String
  rating       Int // 1-5
  comment      String?
  isApproved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId, isApproved])
  @@index([rating])
}

// 💳 ABONNEMENTS
model Subscription {
  id                   String             @id @default(uuid())
  restaurantId         String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               SubscriptionStatus
  plan                 String             @default("STARTER")
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
}
